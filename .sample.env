 NEVER commit .env to Git

# From Meta Developer Dashboard → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_meta_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# You invent this — paste the same string into Meta's webhook settings
VERIFY_TOKEN=apextiles_webhook_secret_2024

# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Only needed if using voice note transcription via OpenAI Whisper
OPENAI_API_KEY=sk-...

# Optional: Slack webhook for human handoff notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Port (hosting platforms like Railway set this automatically)
PORT=3000
